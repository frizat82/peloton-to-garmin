@page "/garminmerge"
@using SharedUI.Shared
@inherits TracingComponentBase
@inject IApiClient _apiClient
@inject IHxMessengerService _toaster

<PageTitle>Activity Merge</PageTitle>

<GarminMfaModal @ref="_garminMfaModal" />

<HxCard CssClass="mb-3">
    <HeaderTemplate>
        <strong>Activity Merge</strong>
        <small class="text-muted ms-2">Match Peloton workouts to existing Garmin device activities and enrich them with Peloton-only stats</small>
    </HeaderTemplate>
    <BodyTemplate>
        <p>
            When <b>Merge with Garmin device activities</b> is enabled in Settings, P2G automatically matches Peloton workouts to Garmin device-recorded activities and enriches them with Peloton stats (power, cadence, resistance, speed, class title). The matched workout file is skipped — no duplicate is uploaded.
        </p>
        <p>
            Use the table below to see past merges, or trigger a manual merge for a workout the auto-sync missed.
        </p>
    </BodyTemplate>
</HxCard>

<HxCard CssClass="mb-3">
    <HeaderTemplate>Manual Merge</HeaderTemplate>
    <BodyTemplate>
        <div class="row g-3 align-items-end">
            <div class="col-md-6">
                <HxInputText Label="Peloton Workout ID" @bind-Value="_manualWorkoutId" Placeholder="e.g. a1b2c3d4e5f6..." />
            </div>
            <div class="col-md-3">
                <HxButton OnClick="ManualMergeAsync" Color="ThemeColor.Primary" Enabled="@(!string.IsNullOrWhiteSpace(_manualWorkoutId))">
                    Merge
                </HxButton>
            </div>
        </div>
        <HxAlert Color="ThemeColor.Info" CssClass="mt-2">
            <HxIcon Icon="@BootstrapIcon.InfoCircle" /> You can find Peloton workout IDs on the <a href="sync">Sync</a> page by selecting a workout and noting its ID in the URL, or from the Peloton app/website.
        </HxAlert>
    </BodyTemplate>
</HxCard>

<HxCard>
    <HeaderTemplate>
        Merge History
        <HxButton Icon="BootstrapIcon.ArrowClockwise" Color="ThemeColor.Light" Size="ButtonSize.Small" OnClick="LoadMergeHistoryAsync" CssClass="ms-2" Tooltip="Refresh" />
    </HeaderTemplate>
    <BodyTemplate>
        @if (_loading)
        {
            <HxSpinner Color="ThemeColor.Primary" />
        }
        else
        {
            <HxGrid TItem="GarminMergeRecordDto" DataProvider="MergeRecordsDataProviderAsync" Responsive="true" PageSize="50">
                <Columns>
                    <HxGridColumn TItem="GarminMergeRecordDto" HeaderText="Merged At" ItemTextSelector="@(item => item.MergedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))" />
                    <HxGridColumn TItem="GarminMergeRecordDto" HeaderText="Peloton Workout" ItemTextSelector="@(item => item.PelotonWorkoutTitle)" />
                    <HxGridColumn TItem="GarminMergeRecordDto" HeaderText="Garmin Activity ID" ItemTextSelector="@(item => item.GarminActivityId.ToString())" />
                    <HxGridColumn TItem="GarminMergeRecordDto" HeaderText="Source">
                        <ItemTemplate>
                            @if (context.Source == MergeSourceDto.Auto)
                            {
                                <HxBadge Color="ThemeColor.Success">Auto</HxBadge>
                            }
                            else
                            {
                                <HxBadge Color="ThemeColor.Primary">Manual</HxBadge>
                            }
                        </ItemTemplate>
                    </HxGridColumn>
                </Columns>
                <EmptyDataTemplate>
                    <p class="text-muted">No merge records yet. Enable <b>Merge with Garmin device activities</b> in Settings and run a sync.</p>
                </EmptyDataTemplate>
            </HxGrid>
        }
    </BodyTemplate>
</HxCard>

@if (_fitBackups is { Count: > 0 })
{
    <HxCard CssClass="mb-3">
        <HeaderTemplate>
            <strong>Original Watch FIT Backups</strong>
            <small class="text-muted ms-2">Saved before merge — download to recover HR / GPS data</small>
        </HeaderTemplate>
        <BodyTemplate>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>File</th>
                            <th>Date</th>
                            <th>Size</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var backup in _fitBackups)
                        {
                            <tr>
                                <td class="small text-break">@backup.FileName</td>
                                <td class="small text-nowrap">@backup.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="small text-nowrap">@($"{backup.SizeBytes / 1024.0:F1} KB")</td>
                                <td>
                                    <a href="api/garminmerge/fit-backups/@Uri.EscapeDataString(backup.FileName)"
                                       class="btn btn-sm btn-outline-secondary" download="@backup.FileName">
                                        Download
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </BodyTemplate>
    </HxCard>
}

@code {
    private ICollection<GarminMergeRecordDto>? _records;
    private ICollection<FitBackupItem>? _fitBackups;
    private string _manualWorkoutId = string.Empty;
    private bool _loading = false;

    private GarminMfaModal? _garminMfaModal;

    public GarminMerge() : base(nameof(GarminMerge)) { }

    protected override async Task OnInitializedAsync()
    {
        using var tracing = Tracing.ClientTrace($"{nameof(GarminMerge)}.{nameof(OnInitializedAsync)}", kind: ActivityKind.Client);
        await Task.WhenAll(LoadMergeHistoryAsync(), LoadFitBackupsAsync());
    }

    private async Task LoadFitBackupsAsync()
    {
        try
        {
            var response = await _apiClient.GetFitBackupsAsync();
            _fitBackups = response.Items;
        }
        catch (Exception e)
        {
            Log.Warning("UI - Could not load FIT backups: {Message}", e.Message);
            _fitBackups = Array.Empty<FitBackupItem>();
        }
    }

    private Task<GridDataProviderResult<GarminMergeRecordDto>> MergeRecordsDataProviderAsync(GridDataProviderRequest<GarminMergeRecordDto> request)
    {
        return Task.FromResult(new GridDataProviderResult<GarminMergeRecordDto>
        {
            Data = _records ?? Array.Empty<GarminMergeRecordDto>(),
            TotalCount = _records?.Count ?? 0,
        });
    }

    private async Task LoadMergeHistoryAsync()
    {
        using var tracing = Tracing.ClientTrace($"{nameof(GarminMerge)}.{nameof(LoadMergeHistoryAsync)}", kind: ActivityKind.Client);
        _loading = true;
        try
        {
            var response = await _apiClient.GarminMergeGetAsync();
            _records = response.Records;
        }
        catch (ApiClientException e)
        {
            _toaster.AddError(e.Message);
            Log.Error("UI - Failed to load merge history.", e);
        }
        catch (Exception e)
        {
            _toaster.AddError($"Failed to load merge history - {e.Message}");
            Log.Error("UI - Failed to load merge history.", e);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ManualMergeAsync()
    {
        using var tracing = Tracing.ClientTrace($"{nameof(GarminMerge)}.{nameof(ManualMergeAsync)}", kind: ActivityKind.Client);
        _toaster.Clear();
        await _garminMfaModal!.ShowAsync(ContinueManualMergeAsync);
    }

    private async Task ContinueManualMergeAsync()
    {
        using var tracing = Tracing.ClientTrace($"{nameof(GarminMerge)}.{nameof(ContinueManualMergeAsync)}", kind: ActivityKind.Client);

        try
        {
            var result = await _apiClient.GarminMergePostAsync(new GarminMergePostRequest { WorkoutId = _manualWorkoutId });
            _manualWorkoutId = string.Empty;

            if (result.Success)
            {
                _toaster.AddInformation(result.Message);
                await LoadMergeHistoryAsync();
            }
            else
            {
                _toaster.AddError(result.Message);
            }
        }
        catch (SyncTimeoutException te)
        {
            _toaster.AddInformation("Long running merge will continue in the background.");
            Log.Information("UI - Merge timeout reached.", te);
        }
        catch (ApiClientException e)
        {
            _toaster.AddError(e.Message);
            Log.Error("UI - Failed to merge activity.", e);
        }
        catch (Exception e)
        {
            _toaster.AddError($"Failed to merge - {e.Message} - See logs for details.");
            Log.Error("UI - Failed to merge activity.", e);
        }
    }
}
